// Public-safe defaults for open-source checkouts.
// These values are intentionally inert. Use Config/Signing.local.xcconfig for
// real Apple team IDs, bundle IDs, app groups, and CloudKit containers.

TALKIE_DEVELOPMENT_TEAM =

