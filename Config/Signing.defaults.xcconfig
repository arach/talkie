// Default Talkie signing identifiers.
// Fresh source checkouts build unsigned by default. Use
// Config/Signing.local.xcconfig for machine-local Apple team IDs,
// signed local builds, or per-account overrides.

TALKIE_DEVELOPMENT_TEAM =
TALKIE_CODE_SIGNING_ALLOWED = NO
TALKIE_CODE_SIGNING_REQUIRED = NO
TALKIE_CODE_SIGN_STYLE = Automatic
TALKIE_CODE_SIGN_IDENTITY = Apple Development

// Agent-specific overrides. The TalkieAgent target reads these directly so its
// signing can be enabled independently of the other macOS targets (Talkie,
// TalkieSync, etc.), which is required for stable TCC grants on dev builds.
TALKIE_AGENT_CODE_SIGNING_ALLOWED = $(TALKIE_CODE_SIGNING_ALLOWED)
TALKIE_AGENT_CODE_SIGNING_REQUIRED = $(TALKIE_CODE_SIGNING_REQUIRED)

CODE_SIGNING_ALLOWED = $(TALKIE_CODE_SIGNING_ALLOWED)
CODE_SIGNING_REQUIRED = $(TALKIE_CODE_SIGNING_REQUIRED)

TALKIE_APP_IDENTIFIER = to.talkie.app
TALKIE_IOS_APP_BUNDLE_ID = to.talkie.app
TALKIE_IOS_SHARE_BUNDLE_ID = to.talkie.app.share
TALKIE_IOS_KEYS_BUNDLE_ID = to.talkie.app.keys
TALKIE_IOS_WIDGET_BUNDLE_ID = to.talkie.app.widgets
TALKIE_WATCH_APP_BUNDLE_ID = to.talkie.app.watchkitapp
TALKIE_WATCH_WIDGET_BUNDLE_ID = to.talkie.app.watchkitapp.widgets
TALKIE_IOS_TESTS_BUNDLE_ID = to.talkie.app.tests
TALKIE_IOS_UITESTS_BUNDLE_ID = to.talkie.app.uitests

TALKIE_MAC_CORE_BUNDLE_ID = to.talkie.app.mac
TALKIE_MAC_CORE_BUNDLE_ID_DEBUG = to.talkie.app.mac.dev
TALKIE_MAC_AGENT_BUNDLE_ID = to.talkie.agent
TALKIE_MAC_AGENT_BUNDLE_ID_DEBUG = to.talkie.agent.dev
TALKIE_MAC_AGENT_TESTS_BUNDLE_ID = to.talkie.agent.tests
TALKIE_MAC_AGENT_UITESTS_BUNDLE_ID = to.talkie.agent.uitests
TALKIE_MAC_SYNC_BUNDLE_ID = to.talkie.app.sync
TALKIE_MAC_SYNC_BUNDLE_ID_DEBUG = to.talkie.app.sync.dev

TALKIE_IOS_APP_GROUP = group.to.talkie.app
TALKIE_IOS_CLOUDKIT_CONTAINER = iCloud.to.talkie
TALKIE_MAC_APP_GROUP = group.to.talkie.app.mac
TALKIE_MAC_SHARED_SETTINGS_SUITE = to.talkie.app.shared
TALKIE_CLOUDKIT_CONTAINER = iCloud.to.talkie
