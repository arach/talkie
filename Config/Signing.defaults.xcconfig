// Public-safe defaults for source-available checkouts.
// No Apple team is configured here, so these values build unsigned by default.
// Use Config/Signing.local.xcconfig for signed local/dev/release builds.

TALKIE_DEVELOPMENT_TEAM =
TALKIE_CODE_SIGNING_ALLOWED = NO
TALKIE_CODE_SIGNING_REQUIRED = NO

CODE_SIGNING_ALLOWED = $(TALKIE_CODE_SIGNING_ALLOWED)
CODE_SIGNING_REQUIRED = $(TALKIE_CODE_SIGNING_REQUIRED)

TALKIE_APP_IDENTIFIER = to.talkie.app
TALKIE_IOS_APP_BUNDLE_ID = to.talkie.app.ios
TALKIE_IOS_SHARE_BUNDLE_ID = to.talkie.app.ios.share
TALKIE_IOS_KEYS_BUNDLE_ID = to.talkie.app.ios.keys
TALKIE_IOS_WIDGET_BUNDLE_ID = to.talkie.app.ios.widgets
TALKIE_WATCH_APP_BUNDLE_ID = to.talkie.app.ios.watch
TALKIE_WATCH_WIDGET_BUNDLE_ID = to.talkie.app.ios.watch.widgets
TALKIE_IOS_TESTS_BUNDLE_ID = to.talkie.app.ios.tests
TALKIE_IOS_UITESTS_BUNDLE_ID = to.talkie.app.ios.uitests

TALKIE_MAC_CORE_BUNDLE_ID = to.talkie.app.mac
TALKIE_MAC_CORE_BUNDLE_ID_DEBUG = to.talkie.app.mac.dev
TALKIE_MAC_AGENT_BUNDLE_ID = to.talkie.app.agent
TALKIE_MAC_AGENT_BUNDLE_ID_DEBUG = to.talkie.app.agent.dev
TALKIE_MAC_AGENT_TESTS_BUNDLE_ID = to.talkie.app.agent.tests
TALKIE_MAC_AGENT_UITESTS_BUNDLE_ID = to.talkie.app.agent.uitests
TALKIE_MAC_SYNC_BUNDLE_ID = to.talkie.app.sync
TALKIE_MAC_SYNC_BUNDLE_ID_DEBUG = to.talkie.app.sync.dev

TALKIE_IOS_APP_GROUP = group.to.talkie.app.ios
TALKIE_IOS_CLOUDKIT_CONTAINER = iCloud.to.talkie.ios
TALKIE_MAC_APP_GROUP = group.to.talkie.app.mac
TALKIE_MAC_SHARED_SETTINGS_SUITE = to.talkie.app.shared
TALKIE_CLOUDKIT_CONTAINER = iCloud.to.talkie
