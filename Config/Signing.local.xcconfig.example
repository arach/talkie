// Copy this file to Config/Signing.local.xcconfig and replace the placeholders.
// Config/Signing.local.xcconfig is ignored by git.
//
// This file configures identifiers. Keep credentials and private keys in your
// secret manager or keychain, not in xcconfig files.

#include "Signing.defaults.xcconfig"

