{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "module": "none",
    "outFile": "dist/hudson.js",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "removeComments": false,
    "strict": false,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  },
  "files": [
    "core/types.ts",
    "core/viewport.ts",
    "core/history.ts",
    "core/hit-test.ts",
    "core/selection.ts",
    "tools/shape-tools.ts",
    "chrome/shell.ts",
    "index.ts"
  ]
}
