<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Talkie Agent</title>

    <!-- Custom branding - light and dark mode backgrounds -->
    <background file="background.png" alignment="bottomleft" scaling="proportional"/>
    <background-darkAqua file="background-dark.png" alignment="bottomleft" scaling="proportional"/>

    <!-- Content pages -->
    <welcome file="welcome-live.html"/>
    <license file="license.html"/>
    <conclusion file="conclusion-live.html"/>

    <options customize="never" require-scripts="false" hostArchitectures="arm64,x86_64"/>

    <choices-outline>
        <line choice="default"/>
    </choices-outline>

    <!-- Single choice containing both packages -->
    <choice id="default"
            title="Talkie Agent"
            description="Includes Talkie Agent with the embedded local transcription engine."
            visible="false">
        <pkg-ref id="jdi.talkie.agent"/>
    </choice>

    <pkg-ref id="jdi.talkie.agent" version="1.3.0" installKBytes="7400">TalkieAgent.pkg</pkg-ref>

</installer-gui-script>
