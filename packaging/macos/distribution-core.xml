<?xml version="1.0" encoding="utf-8"?>
<installer-gui-script minSpecVersion="2">
    <title>Talkie for Mac</title>

    <!-- Custom branding - light and dark mode backgrounds -->
    <background file="background.png" alignment="bottomleft" scaling="proportional"/>
    <background-darkAqua file="background-dark.png" alignment="bottomleft" scaling="proportional"/>

    <!-- Content pages -->
    <welcome file="welcome-core.html"/>
    <license file="license.html"/>
    <conclusion file="conclusion-core.html"/>

    <options customize="never" require-scripts="false" hostArchitectures="arm64,x86_64"/>

    <choices-outline>
        <line choice="default"/>
    </choices-outline>

    <!-- Single choice containing both packages -->
    <choice id="default"
            title="Talkie for Mac"
            description="Includes Talkie Agent and Talkie app."
            visible="false">
        <pkg-ref id="to.talkie.agent"/>
        <pkg-ref id="to.talkie.app.mac"/>
    </choice>

    <pkg-ref id="to.talkie.agent" version="1.3.0" installKBytes="7400">TalkieAgent.pkg</pkg-ref>
    <pkg-ref id="to.talkie.app.mac" version="1.3.0" installKBytes="15000">TalkieCore.pkg</pkg-ref>

</installer-gui-script>
