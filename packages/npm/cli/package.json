{
  "name": "@talkie/cli",
  "version": "0.4.9",
  "description": "Talkie CLI for macOS — voice memos, dictations, screenshots, screen clips, search, and agent workflows",
  "type": "module",
  "bin": {
    "talkie": "dist/index.js"
  },
  "files": [
    "README.md",
    "src",
    "!src/dev.ts",
    "!src/commands/dev",
    "dist/index.js",
    "SKILL.md"
  ],
  "scripts": {
    "dev": "bun run src/dev.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "prepublishOnly": "bun run build",
    "link": "bun link && ln -sf \"$(pwd)/src/dev.ts\" \"$HOME/.bun/bin/talkie-dev\""
  },
  "keywords": [
    "talkie",
    "macos",
    "cli",
    "voice-memos",
    "dictation",
    "transcription",
    "screenshots",
    "screen-capture",
    "screen-clips",
    "sqlite",
    "ai-agent",
    "workflows"
  ],
  "author": "Arach Tchoupani <arach@tchoupani.com>",
  "license": "PolyForm-Noncommercial-1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arach/talkie.git",
    "directory": "packages/npm/cli"
  },
  "bugs": {
    "url": "https://github.com/arach/talkie/issues"
  },
  "homepage": "https://usetalkie.com",
  "engines": {
    "bun": ">=1.0.0"
  },
  "os": [
    "darwin"
  ],
  "dependencies": {
    "gunshi": "^0.36.0"
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
